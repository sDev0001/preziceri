{
  "version": 2,
  "routes": [
    { "src": "/api/teams", "dest": "/api/teams.js" },
    { "src": "/api/predict", "dest": "/api/predict.js" },
    { "src": "/api/backtest", "dest": "/api/backtest.js" },
    { "src": "/api/upcoming", "dest": "/api/upcoming.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
